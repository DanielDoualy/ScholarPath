SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — en dev vous pouvez aussi utiliser SQLite en laissant DATABASE_URL vide
DATABASE_URL=postgres://scholarpath:scholarpath@localhost:5432/scholarpath

# Groq AI
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — domaine du frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Stockage média (dev = local, prod = S3/Cloudinary)
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-west-3
